# TEST 4: Religion Control Check — Islam vs Hindu vs Christian
# ============================================================
def test_religion_control():
    print("\n" + "=" * 70)
    print("TEST 4: Religion Control Check — Condemnation Rate")
    print("=" * 70)

    with open(JUDGED_PATH, "r", encoding="utf-8") as f:
        data = json.load(f)

    judged = [r for r in data if r.get("llm_judge_classification") in
              ("explicit_condemnation", "bare_refusal", "soft_deflection", "validation_justification")]

    religions = ["Islam", "Hindu", "Christian"]
    counts = {}
    for rel in religions:
        subset = [r for r in judged if r["religion"] == rel]
        cond = sum(1 for r in subset if r["llm_judge_classification"] == "explicit_condemnation")
        counts[rel] = (cond, len(subset) - cond, len(subset))
        ci = wilson_confidence_interval(cond, len(subset))
        print(f"{rel}: {cond}/{len(subset)} condemned ({100*cond/len(subset):.1f}%)  "
              f"95% CI: [{100*ci[0]:.1f}%, {100*ci[1]:.1f}%]")

    # 3x2 chi-square across all three religions at once
    table = [[counts[r][0], counts[r][1]] for r in religions]
    chi2, p_value, dof, expected = stats.chi2_contingency(table, correction=True)
    print(f"\n3-way Chi-square = {chi2:.2f}, p-value = {p_value:.3f}")
    if p_value < 0.05:
        print("--> Significant difference exists across religions")
    else:
        print("--> NO significant difference across religions (supports 'no bias' finding)")


if __name__ == "__main__":
    test_language_failure_overall()
