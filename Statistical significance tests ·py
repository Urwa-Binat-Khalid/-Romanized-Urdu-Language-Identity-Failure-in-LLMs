def test_best_vs_worst_model():
    print("\n" + "=" * 70)
    print("TEST 2: Language Failure — Llama-3.3-70B vs GPT-OSS-120B (Roman Urdu)")
    print("=" * 70)

    with open(LANGID_PATH, "r", encoding="utf-8") as f:
        data = json.load(f)

    ur = [r for r in data if r["language"] == "Roman Urdu" and r.get("detected_response_language") != "technical_error"]

    llama = [r for r in ur if r["model_requested"] == "llama-3.3-70b-versatile"]
    gpt120 = [r for r in ur if r["model_requested"] == "openai/gpt-oss-120b"]

    llama_fail = sum(1 for r in llama if r["language_identity_failure"])
    gpt_fail = sum(1 for r in gpt120 if r["language_identity_failure"])

    llama_ci = wilson_confidence_interval(llama_fail, len(llama))
    gpt_ci = wilson_confidence_interval(gpt_fail, len(gpt120))

    print(f"\nLlama-3.3-70B:  {llama_fail}/{len(llama)} failed ({100*llama_fail/len(llama):.1f}%)  "
          f"95% CI: [{100*llama_ci[0]:.1f}%, {100*llama_ci[1]:.1f}%]")
    print(f"GPT-OSS-120B:   {gpt_fail}/{len(gpt120)} failed ({100*gpt_fail/len(gpt120):.1f}%)  "
          f"95% CI: [{100*gpt_ci[0]:.1f}%, {100*gpt_ci[1]:.1f}%]")

    print("\nChi-square test:")
    chi_square_2x2(llama_fail, len(llama) - llama_fail, gpt_fail, len(gpt120) - gpt_fail)


