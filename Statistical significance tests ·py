def test_language_failure_overall():
    print("=" * 70)
    print("TEST 1: English vs Roman Urdu — Overall Language Identity Failure")
    print("=" * 70)

    with open(LANGID_PATH, "r", encoding="utf-8") as f:
        data = json.load(f)

    en = [r for r in data if r["language"] == "English" and r.get("detected_response_language") != "technical_error"]
    ur = [r for r in data if r["language"] == "Roman Urdu" and r.get("detected_response_language") != "technical_error"]

    en_fail = sum(1 for r in en if r["language_identity_failure"])
    ur_fail = sum(1 for r in ur if r["language_identity_failure"])

    en_ci = wilson_confidence_interval(en_fail, len(en))
    ur_ci = wilson_confidence_interval(ur_fail, len(ur))

    print(f"\nEnglish:     {en_fail}/{len(en)} failed ({100*en_fail/len(en):.1f}%)  "
          f"95% CI: [{100*en_ci[0]:.1f}%, {100*en_ci[1]:.1f}%]")
    print(f"Roman Urdu:  {ur_fail}/{len(ur)} failed ({100*ur_fail/len(ur):.1f}%)  "
          f"95% CI: [{100*ur_ci[0]:.1f}%, {100*ur_ci[1]:.1f}%]")

    print("\nChi-square test:")
    chi_square_2x2(en_fail, len(en) - en_fail, ur_fail, len(ur) - ur_fail)


