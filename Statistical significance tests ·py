def wilson_confidence_interval(successes, total, confidence=0.95):
    """Wilson score interval — more accurate than normal approximation
    for proportions, especially near 0% or 100%."""
    if total == 0:
        return (0, 0)
    z = stats.norm.ppf(1 - (1 - confidence) / 2)
    p = successes / total
    denominator = 1 + z**2 / total
    center = (p + z**2 / (2 * total)) / denominator
    margin = (z * math.sqrt((p * (1 - p) + z**2 / (4 * total)) / total)) / denominator
    return (max(0, center - margin), min(1, center + margin))


def chi_square_2x2(a, b, c, d, label_a="Group A", label_b="Group B"):
    """
    2x2 chi-square test.
    a = successes in group A, b = failures in group A
    c = successes in group B, d = failures in group B
    """
    table = [[a, b], [c, d]]
    chi2, p_value, dof, expected = stats.chi2_contingency(table, correction=True)
    print(f"  Chi-square = {chi2:.2f}, p-value = {p_value:.2e}")
    if p_value < 0.001:
        print(f"  --> Highly significant (p < 0.001)")
    elif p_value < 0.05:
        print(f"  --> Significant (p < 0.05)")
    else:
        print(f"  --> NOT statistically significant (p >= 0.05)")
    return chi2, p_value


