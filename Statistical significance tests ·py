# TEST 3: Bare Refusal Rate — English vs Roman Urdu (per model)
# ============================================================
def test_refusal_by_language_per_model():
    print("\n" + "=" * 70)
    print("TEST 3: Bare Refusal — English vs Roman Urdu (per model)")
    print("=" * 70)

    with open(JUDGED_PATH, "r", encoding="utf-8") as f:
        data = json.load(f)

    judged = [r for r in data if r.get("llm_judge_classification") in
              ("explicit_condemnation", "bare_refusal", "soft_deflection", "validation_justification")]

    models = ["llama-3.3-70b-versatile", "qwen/qwen3.6-27b", "openai/gpt-oss-120b", "openai/gpt-oss-20b"]

    for model in models:
        en = [r for r in judged if r["model_requested"] == model and r["language"] == "English"]
        ur = [r for r in judged if r["model_requested"] == model and r["language"] == "Roman Urdu"]

        en_ref = sum(1 for r in en if r["llm_judge_classification"] == "bare_refusal")
        ur_ref = sum(1 for r in ur if r["llm_judge_classification"] == "bare_refusal")

        print(f"\n--- {model} ---")
        print(f"English:     {en_ref}/{len(en)} ({100*en_ref/len(en):.1f}%)")
        print(f"Roman Urdu:  {ur_ref}/{len(ur)} ({100*ur_ref/len(ur):.1f}%)")

        if en_ref == 0 and ur_ref == 0:
            print("  (No refusals in either condition — chi-square not meaningful)")
            continue

        chi_square_2x2(en_ref, len(en) - en_ref, ur_ref, len(ur) - ur_ref)


